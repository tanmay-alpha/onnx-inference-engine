# =============================================================================
# Crucible — Git Ignore System
# =============================================================================

# Build directories
engine/build/
cli/target/
wasm/target/
wasm/pkg/
web/.next/
build/
dist/
out/
.turbo/

# Package managers & dependencies
node_modules/
_deps/

# Python caching & environments
__pycache__/
*.pyc
*.py[cod]
*$py.class
*.egg-info/
.eggs/
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Dynamic libraries & native binaries
*.so
*.so.*
*.dylib
*.dll
*.o
*.obj
*.a
*.lib
*.exe
*.pdb
*.ilk
*.exp
*.idb

# Configuration & environment variables
.env
.env.local
.env.development
.env.production
.env.staging

# OS & editor artifacts
.DS_Store
Thumbs.db
desktop.ini
.vscode/
.idea/
*.swp
*.swo

# Backup & temporary files
*.orig
*.bak
Cargo.lock.bak

# Large model artifacts
models/*.onnx
models/*.pt
models/*.pth
!models/.gitkeep
!models/download_models.py

# Benchmark outputs
benchmarks/results/benchmark_results.json
!benchmarks/results/.gitkeep
