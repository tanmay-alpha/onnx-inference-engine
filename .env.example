# Crucible environment configuration
# Copy this file to .env and fill in your values.

# Directory for storing uploaded ONNX models
CRUCIBLE_MODEL_DIR=/tmp/models

# Path to the C++ engine shared library (libcrucible.so / libcrucible.dylib / crucible.dll)
CRUCIBLE_ENGINE_PATH=/usr/local/lib/libcrucible.so

# API key for authenticated endpoints (change in production)
CRUCIBLE_API_KEY=change-me-in-production

# Maximum allowed model file size in megabytes
CRUCIBLE_MAX_MODEL_SIZE_MB=100
