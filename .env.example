# Crucible Environment Configuration
# Copy this file to .env and fill in your values before running.

# ─── Database ────────────────────────────────────────────────────────────────
# SQLite (dev): DATABASE_URL=sqlite+aiosqlite:///./crucible.db
# PostgreSQL (prod) — change this to your local Postgres connection:
# Format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<dbname>
# Example: postgresql+asyncpg://crucible:crucible_dev_password@localhost:5432/crucible
DATABASE_URL=sqlite+aiosqlite:///./crucible.db

# ─── Server ──────────────────────────────────────────────────────────────────
# Directory for storing uploaded ONNX models
CRUCIBLE_MODEL_DIR=/tmp/models

# API key for authenticated endpoints (change in production!)
CRUCIBLE_API_KEY=change-me-in-production

# Inference timeout in seconds
INFERENCE_TIMEOUT_SEC=60

# Max request body size in bytes
MAX_UPLOAD_BYTES=209715200

# ─── Auth ────────────────────────────────────────────────────────────────────
# JWT signing key — MUST be set in production!
CRUCIBLE_SECRET_KEY=change-me-in-production-use-a-real-secret-min-32-chars

# Token expiry in minutes
CRUCIBLE_TOKEN_EXPIRE_MINUTES=60

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CRUCIBLE_CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── Logging ─────────────────────────────────────────────────────────────────
CRUCIBLE_LOG_LEVEL=INFO
CRUCIBLE_LOG_FORMAT=console

# ─── ML Training ─────────────────────────────────────────────────────────────
# Path to training data CSV (Kaggle CreditCard dataset)
CRUCIBLE_TRAIN_DATA=data/raw/creditcard.csv

# Output path for trained ONNX model
CRUCIBLE_MODEL_OUTPUT=models/fraud_model.onnx

# ─── Frontend ────────────────────────────────────────────────────────────────
# URL of the Crucible API server
NEXT_PUBLIC_API_URL=http://localhost:8000

# ─── Docker / PostgreSQL ─────────────────────────────────────────────────────
POSTGRES_PASSWORD=crucible_dev_password
GRAFANA_PASSWORD=admin
